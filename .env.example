# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=rag_database
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
EMBED_MODEL=bge-m3

# ── ChromaDB 컬렉션 ─────────────────────────────────────────────────────────────
COLLECTION_NAME=scholarship_rules
VECTOR_MIN_RELEVANCE=0.35
VECTOR_SEARCH_K=8
VECTOR_SEARCH_FETCH_K=30

# ── API Security ───────────────────────────────────────────────────────────────
# 설정하면 /chat, /summary, /ingest 요청에 X-API-Key 헤더 필수. 비워두면 인증 없음(개발용).
API_KEY=change_me_api_key

# ── Ingest Security ────────────────────────────────────────────────────────────
# /ingest 엔드포인트가 허용하는 최상위 디렉토리 (기본: backend/data)
# INGEST_ALLOWED_BASE=/absolute/path/to/allowed/folder

# ── Image table OCR ────────────────────────────────────────────────────────────
# PaddleOCR 한국어 인식 모델과 셀 배치 크기. CPU 메모리가 부족하면 배치를 줄이세요.
PADDLEOCR_REC_MODEL=korean_PP-OCRv5_mobile_rec
IMAGE_OCR_CELL_BATCH=64
