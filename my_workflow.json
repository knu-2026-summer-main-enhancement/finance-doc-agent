    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst files = data.files || [];\n\nif (files.length === 0) {\n  return [{ json: { text: '현재 색인된 문서가 없습니다.' } }];\n}\n\nconst statusEmoji = { SUCCESS: '✅', FAILED: '❌', IN_PROGRESS: '⏳' };\n\nconst lines = files.map(f => {\n  const emoji = statusEmoji[f.status] || '❓';\n  const count = f.chroma_doc_count ? ` (${f.chroma_doc_count}건)` : '';\n  return `${emoji} ${f.source}${count}`;\n});\n\nreturn [{\n  json: {\n    text: `현재 색인된 문서 (${files.length}개):\\n${lines.join('\\n')}`\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1220,
        700
      ],
      "id": "5cdb2b3a-6497-4d3d-9985-4d6d682c24b0",
